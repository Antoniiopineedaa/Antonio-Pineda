# Variables de entorno para la función /api/subscribe.
# NO se ponen aquí en el repo: se pegan en Vercel → Settings → Environment Variables.
# Este archivo solo documenta cuáles hacen falta.

# beehiiv → Settings → API → Create New API Key
BEEHIIV_API_KEY=

# El ID de tu publicación de beehiiv (empieza por "pub_").
# Lo ves en la URL del panel o en Settings.
BEEHIIV_PUBLICATION_ID=
